# Backend Environment Variables — EXEMPLO
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env com valores reais.

# Banco de dados (Supabase PostgreSQL ou local)
DATABASE_URL=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT Secret do Supabase — Obter em: Supabase Dashboard → Settings → API → JWT Secret
# OBRIGATÓRIO para validação de autenticação em produção
SUPABASE_JWT_SECRET=

# URL do frontend (usada para gerar links de convite por e-mail)
FRONTEND_URL=http://localhost:5173

# Ambiente (development | production)
ENVIRONMENT=development

# Modo de desenvolvimento — habilita logs extras; não desabilita mais controles de segurança
DEV_MODE=false

# Modo de autenticação mock — APENAS para desenvolvimento local explícito
# Nunca definir como true em produção
ENABLE_MOCK_AUTH=false

# Resend (serviço de e-mail para convites)
RESEND_API_KEY=
