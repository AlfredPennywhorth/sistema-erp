# Frontend Environment Variables — EXEMPLO
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env com valores reais.

# Supabase — Obter em: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL base do backend FastAPI
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Modo de debug — habilita logs extras no console; manter false em produção
VITE_DEBUG_MODE=false

# Modo de autenticação mock — APENAS para desenvolvimento local explícito
# Requer que o backend também tenha ENABLE_MOCK_AUTH=true
# Nunca definir como true em produção
VITE_ENABLE_MOCK_AUTH=false
